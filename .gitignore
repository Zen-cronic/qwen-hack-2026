# Secrets — the live QWEN_API_KEY lives here; never commit it
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/

# Generated media + run state — large, regenerable, shipped to the box via rsync (not git)
data/

# Frontend build artifacts
node_modules/
web/dist/
web/test-results/
web/playwright-report/

# OS / editor
.DS_Store
*.swp

# Claude Code — local machine state, not shared (the skill under .claude/skills IS committed)
.claude/settings.local.json
.playwright-mcp/
.claude/commands/
.claude/workflows/
.claude/skills/*
!.claude/skills/frontend-design/

references/

# Demo-video production — capture harness, Remotion composition, takes, renders.
# Stays local by operator decision; nothing here ships with the submission.
film/

# playwright-mcp session artifacts (screenshots, flow recordings)
.playwright-mcp/

# Private keys — never in the tree. The CI keypair belongs in ~/.ssh (docs/deploy.md
# step 2); this is the backstop for anyone who runs ssh-keygen from the repo root.
*.pem
*_ed25519
*_rsa
qwen-hack-2026-ci*
id_*
!id_*.md
