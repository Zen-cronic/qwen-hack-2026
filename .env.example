# Qwen Cloud API key — https://bit.ly/qwencloud-getapi
# NOTE: if your key starts with sk-sp- it is a Token Plan key and QWEN_BASE_URL
# must be https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
# (mismatched key/endpoint pairs return 401 InvalidApiKey — Build Session FAQ)
QWEN_API_KEY=

# OpenAI-compatible base URL — chat + VLM (must remain visible in code: submission requirement)
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Native DashScope REST host — async video/image task API (/api/v1/...). Same host, different surface.
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com

# --- VERIFIED console roster (docs/verification.md, live-tested 2026-07-06) — this governs ---

# Chat / reasoning (scripts + repair prompts)
QWEN_CHAT_MODEL=qwen-plus

# Vision-language for Tier-B semantic verdicts — UNVERIFIED; gated by scripts/smoke_vl.py.
# On GO the probe pins VL_MODEL + VL_SHAPE here; on NO-GO Tier B stays stubbed to human verdicts.
VL_MODEL=qwen-vl-plus
VL_SHAPE=openai          # openai (image_url parts) | dashscope (multimodal-generation)

# Video generation — iterate cheap on turbo (40x5s free), certify on plus (10x5s free)
WAN_DRAFT_MODEL=wan2.1-t2v-turbo
WAN_FINAL_MODEL=wan2.2-t2v-plus

# Text-to-image stills for Tier-0 pre-screen (1/25th of video cost)
WAN_T2I_MODEL=wan2.1-t2i-plus

# Judge mode: cap fresh clips/session; cached-clip re-verification bypasses caps at zero video cost
JUDGE_MODE=0

# --- Doc-roster alternates (Build Session FAQ, 2026-06-30) — NOT on the verified console. ---
# Swap in only if a probe confirms access on your account:
#   QWEN_CHAT_MODEL=qwen3.7-plus   WAN_T2I_MODEL=wan2.6-t2i
#   WAN_DRAFT_MODEL=happyhorse-1.1 (video)   TTS_MODEL=cosyvoice-v3-plus
